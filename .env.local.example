# =============================================================================
# ZsuzsiCRM — Environment Variables
# Copy this file to .env.local and fill in every value before running.
# NEVER commit .env.local to git — it is already in .gitignore.
# =============================================================================

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Your project's REST + Auth base URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key — safe to expose in the browser (Row Level Security enforces
# access control on the database side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose this in the browser or client-side code.
# Used only in server-side API routes (createAdminClient) to bypass RLS
# for trusted operations (e.g., cron jobs, booking form processing).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Resend (transactional email) ─────────────────────────────────────────────
# Create a free account at https://resend.com
# API keys: https://resend.com/api-keys

# Resend API key (starts with re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for all outgoing emails.
# This domain must be verified in your Resend account.
# For local dev you can use onboarding@resend.dev (limited to your own email).
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Application ──────────────────────────────────────────────────────────────

# The public URL of this CRM deployment.
# Used in notification emails as deep-link base (e.g. /clients/uuid).
# In production: https://crm.utazofotos.com (or your Vercel URL)
# In development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron job authentication ──────────────────────────────────────────────────
# The daily notification cron at /api/cron/notifications is secured with a
# shared secret. Vercel passes this automatically when configured in vercel.json.
# Generate a strong random value: openssl rand -hex 32
CRON_SECRET=replace-with-a-random-64-char-hex-string

# ─── Website booking form integration ────────────────────────────────────────

# Extra CORS origin allowed to POST to /api/booking-form.
# Use this for a staging or preview environment.
# Leave empty if you only need utazofotos.com (already hardcoded).
CORS_EXTRA_ORIGIN=

# Set any non-empty value to enable the dry-run test endpoint
# /api/booking-form/test in production (e.g. on a staging deployment).
# Leave empty to keep it dev-only.
BOOKING_FORM_TEST_KEY=
